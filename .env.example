# ============================================================
# SynoChain AI 环境变量配置示例
# 复制此文件为 .env 并填写真实值
# ============================================================

# PayPal 配置
# 从 https://developer.paypal.com/dashboard/applications/sandbox 获取
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_ENV=sandbox

# Supabase 配置
# 从 https://supabase.com/dashboard/project/_/settings/api 获取
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# OpenAI API 配置
# 从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=
