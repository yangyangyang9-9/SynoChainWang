---
import { useTranslations, type Lang } from '../../i18n/ui';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const faqs = [
  { q: 'faq.q1', a: 'faq.a1' },
  { q: 'faq.q2', a: 'faq.a2' },
  { q: 'faq.q3', a: 'faq.a3' },
  { q: 'faq.q4', a: 'faq.a4' },
  { q: 'faq.q5', a: 'faq.a5' },
];
---

<section class="section-padding bg-ink-50">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-ink-800 sm:text-4xl">
        {t('home.faqTitle')}
      </h2>
    </div>

    <div class="mx-auto mt-12 max-w-3xl space-y-4">
      {faqs.map((faq, index) => (
        <details
          class="group rounded-xl border border-ink-100 bg-white p-6 shadow-sm transition-all hover:shadow-md"
          {...(index === 0 ? { open: true } : {})}
        >
          <summary class="flex cursor-pointer items-center justify-between gap-4 list-none">
            <h3 class="font-display text-base font-semibold text-ink-800 sm:text-lg">
              {t(faq.q)}
            </h3>
            <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-medical-50 text-medical-600 transition-transform group-open:rotate-180">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </span>
          </summary>
          <p class="mt-4 text-sm leading-relaxed text-ink-500 sm:text-base">
            {t(faq.a)}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>
