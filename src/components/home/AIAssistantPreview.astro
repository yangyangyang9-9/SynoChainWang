---
import { useTranslations, type Lang } from '../../i18n/ui';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="ai-assistant" class="section-padding relative overflow-hidden bg-white">
  <!-- 背景装饰 -->
  <div class="absolute left-0 top-1/2 -z-10 h-[500px] w-[500px] -translate-y-1/2 rounded-full bg-medical-100/30 blur-3xl"></div>
  <div class="absolute right-0 top-0 -z-10 h-[400px] w-[400px] rounded-full bg-health-100/30 blur-3xl"></div>

  <div class="container-x">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- 左侧文字 -->
      <div>
        <span class="inline-flex items-center gap-2 rounded-full border border-medical-200 bg-medical-50 px-3 py-1 text-xs font-medium text-medical-700">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-medical-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-medical-500"></span>
          </span>
          {t('ai.badge')}
        </span>

        <h2 class="mt-6 text-3xl font-bold tracking-tight text-ink-800 sm:text-4xl md:text-5xl">
          {t('home.aiAssistantTitle')}
        </h2>
        <p class="mt-6 text-base leading-relaxed text-ink-500 sm:text-lg">
          {t('home.aiAssistantDesc')}
        </p>

        <!-- 特性列表 -->
        <ul class="mt-8 space-y-4">
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-medical-100">
              <svg class="h-3.5 w-3.5 text-medical-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
            </span>
            <div>
              <div class="font-medium text-ink-800">Symptom Analysis</div>
              <div class="text-sm text-ink-500">Describe your symptoms in natural language and get instant AI-powered analysis</div>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-health-100">
              <svg class="h-3.5 w-3.5 text-health-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
            </span>
            <div>
              <div class="font-medium text-ink-800">Possible Factors & Conditions</div>
              <div class="text-sm text-ink-500">AI identifies possible causes and related medical conditions</div>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-medical-100">
              <svg class="h-3.5 w-3.5 text-medical-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
            </span>
            <div>
              <div class="font-medium text-ink-800">{t('ai.feature3Title')}</div>
              <div class="text-sm text-ink-500">{t('ai.feature3Desc')}</div>
            </div>
          </li>
        </ul>

        <a href="/ai-tools" class="btn-primary mt-10">
          {t('home.tryAssistant')}
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- 右侧预览卡片 -->
      <div class="relative">
        <div class="overflow-hidden rounded-2xl border border-ink-100 bg-white shadow-xl">
          <!-- 对话头部 -->
          <div class="flex items-center gap-3 border-b border-ink-100 bg-ink-50 px-6 py-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-medical-500 to-health-500">
              <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
              </svg>
            </div>
            <div>
              <div class="font-display text-sm font-semibold text-ink-800">SynoChain AI Assistant</div>
              <div class="flex items-center gap-1 text-xs text-health-600">
                <span class="h-1.5 w-1.5 rounded-full bg-health-500"></span>
                Online
              </div>
            </div>
          </div>

          <!-- 对话内容 -->
          <div class="space-y-4 p-6">
            <!-- 用户消息 -->
            <div class="flex justify-end">
              <div class="max-w-[80%] rounded-2xl rounded-tr-sm bg-medical-500 px-4 py-3 text-sm text-white">
                I've been having frequent headaches and feeling tired lately. What could be the cause?
              </div>
            </div>

            <!-- AI 回复 -->
            <div class="flex justify-start">
              <div class="max-w-[85%] rounded-2xl rounded-tl-sm bg-ink-50 px-4 py-3 text-sm text-ink-700">
                <p class="font-medium text-ink-800">Possible Factors:</p>
                <ul class="mt-2 space-y-1 text-ink-600">
                  <li>• Stress or tension</li>
                  <li>• Dehydration</li>
                  <li>• Sleep deficiency</li>
                  <li>• Eye strain from screens</li>
                </ul>
                <p class="mt-3 font-medium text-ink-800">Recommended Next Steps:</p>
                <ul class="mt-2 space-y-1 text-ink-600">
                  <li>• Track water intake (8 glasses/day)</li>
                  <li>• Ensure 7-9 hours of sleep</li>
                  <li>• Take screen breaks every 20 min</li>
                </ul>
                <p class="mt-3 text-xs text-ink-400">⚠️ See a doctor if headaches persist &gt; 3 days</p>
              </div>
            </div>
          </div>

          <!-- 输入框预览 -->
          <div class="border-t border-ink-100 p-4">
            <div class="flex items-center gap-2 rounded-xl border border-ink-200 bg-white px-4 py-3">
              <span class="text-ink-400 text-sm">Describe your symptoms...</span>
              <span class="ml-auto flex h-8 w-8 items-center justify-center rounded-lg bg-medical-500 text-white">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
              </span>
            </div>
          </div>
        </div>

        <!-- 浮动装饰 -->
        <div class="absolute -right-4 -top-4 flex h-16 w-16 rotate-12 items-center justify-center rounded-2xl bg-health-500 text-2xl text-white shadow-lg">
          🩺
        </div>
        <div class="absolute -bottom-4 -left-4 flex h-14 w-14 -rotate-12 items-center justify-center rounded-2xl bg-medical-500 text-2xl text-white shadow-lg">
          💊
        </div>
      </div>
    </div>
  </div>
</section>
