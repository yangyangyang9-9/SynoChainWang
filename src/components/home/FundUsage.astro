---
import { useTranslations, type Lang } from '../../i18n/ui';
import { getFundAllocation, defaultFundAllocation } from '../../lib/supabase';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const funds = await getFundAllocation();

// 图标映射
const iconMap: Record<string, string> = {
  server: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
  cpu: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>`,
  smartphone: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
  shield: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
};
---

<section class="section-padding bg-ink-50">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-ink-800 sm:text-4xl">
        {t('home.fundUsageTitle')}
      </h2>
      <p class="mt-4 text-base text-ink-500 sm:text-lg">
        {t('home.fundUsageSubtitle')}
      </p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {funds.map((fund, index) => {
        const colorClass = index === 0 ? 'text-medical-600 bg-medical-50'
          : index === 1 ? 'text-health-600 bg-health-50'
          : index === 2 ? 'text-medical-600 bg-medical-50'
          : 'text-ink-600 bg-ink-100';
        return (
          <div class="card group hover:-translate-y-1">
            <div class={`inline-flex rounded-xl p-3 ${colorClass}`} set:html={iconMap[fund.icon] || iconMap.server} />
            <div class="mt-4 font-display text-4xl font-bold text-ink-800">
              {fund.percentage}%
            </div>
            <h3 class="mt-1 text-lg font-semibold text-ink-700">{fund.name}</h3>
            <p class="mt-2 text-sm text-ink-400">{fund.description}</p>

            <ul class="mt-4 space-y-2">
              {fund.usage.map((item) => (
                <li class="flex items-center gap-2 text-xs text-ink-500">
                  <svg class="h-3.5 w-3.5 flex-shrink-0 text-health-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <path d="M20 6L9 17l-5-5"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>

    <!-- 资金分配可视化条 -->
    <div class="mt-12 rounded-2xl border border-ink-100 bg-white p-6 sm:p-8">
      <div class="mb-4 text-sm font-medium text-ink-700">Fund Allocation Breakdown</div>
      <div class="flex h-4 w-full overflow-hidden rounded-full">
        {funds.map((fund, index) => {
          const bgClass = index === 0 ? 'bg-medical-500'
            : index === 1 ? 'bg-health-500'
            : index === 2 ? 'bg-medical-400'
            : 'bg-ink-400';
          return (
            <div
              class={`${bgClass} transition-all duration-500 hover:brightness-110`}
              style={`width: ${fund.percentage}%`}
              title={`${fund.name}: ${fund.percentage}%`}
            ></div>
          );
        })}
      </div>
      <div class="mt-3 flex flex-wrap gap-x-6 gap-y-2">
        {funds.map((fund, index) => {
          const dotClass = index === 0 ? 'bg-medical-500'
            : index === 1 ? 'bg-health-500'
            : index === 2 ? 'bg-medical-400'
            : 'bg-ink-400';
          return (
            <div class="flex items-center gap-2 text-xs text-ink-500">
              <span class={`h-2.5 w-2.5 rounded-full ${dotClass}`}></span>
              {fund.name} ({fund.percentage}%)
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
