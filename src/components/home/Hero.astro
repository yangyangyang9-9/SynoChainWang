---
import { useTranslations, type Lang } from '../../i18n/ui';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative overflow-hidden bg-white pt-32 pb-20 md:pt-40 md:pb-32">
  <!-- 背景网格 -->
  <div class="absolute inset-0 grid-bg opacity-60"></div>

  <!-- 背景光晕 -->
  <div class="absolute left-1/2 top-0 -z-10 h-[600px] w-[600px] -translate-x-1/2 rounded-full bg-medical-100/40 blur-3xl"></div>
  <div class="absolute right-0 top-40 -z-10 h-[400px] w-[400px] rounded-full bg-health-100/30 blur-3xl"></div>

  <div class="container-x relative">
    <div class="mx-auto max-w-4xl text-center">
      <!-- 标签 -->
      <div class="animate-fade-in mb-6 inline-flex items-center gap-2 rounded-full border border-medical-200 bg-medical-50 px-4 py-1.5 text-xs font-medium text-medical-700">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-health-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-health-500"></span>
        </span>
        {t('hero.badge')}
      </div>

      <!-- 主标题 -->
      <h1 class="animate-slide-up text-4xl font-extrabold leading-tight tracking-tight text-ink-800 sm:text-5xl md:text-6xl lg:text-7xl">
        {t('hero.titleLine1')}
        <span class="gradient-text block sm:inline">{t('hero.titleLine2')}</span>
        {t('hero.titleLine3')}
      </h1>

      <!-- 副标题 -->
      <p class="animate-slide-up animation-delay-200 mx-auto mt-6 max-w-2xl text-base leading-relaxed text-ink-500 sm:text-lg md:text-xl">
        {t('hero.subtitleNew')}
      </p>

      <!-- CTA 按钮 -->
      <div class="animate-slide-up animation-delay-300 mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/medical-fund" class="btn-primary w-full sm:w-auto">
          <span class="text-base">💝</span>
          {t('hero.donateCta')}
        </a>
        <a href="#ai-assistant" class="btn-secondary w-full sm:w-auto">
          {t('home.tryAssistant')}
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- 统计数据 -->
      <div class="animate-slide-up animation-delay-400 mt-16 mx-auto max-w-3xl">
        <div class="grid grid-cols-3 gap-4 sm:gap-8">
          <div class="rounded-2xl border border-ink-100 bg-white/80 p-6 text-center shadow-sm backdrop-blur">
            <div class="font-display text-2xl font-bold text-medical-600 sm:text-3xl">$148K+</div>
            <div class="mt-1 text-xs text-ink-400 sm:text-sm">{t('hero.statRaised')}</div>
          </div>
          <div class="rounded-2xl border border-ink-100 bg-white/80 p-6 text-center shadow-sm backdrop-blur">
            <div class="font-display text-2xl font-bold text-health-600 sm:text-3xl">5,350+</div>
            <div class="mt-1 text-xs text-ink-400 sm:text-sm">{t('hero.statPages')}</div>
          </div>
          <div class="rounded-2xl border border-ink-100 bg-white/80 p-6 text-center shadow-sm backdrop-blur">
            <div class="font-display text-2xl font-bold text-ink-800 sm:text-3xl">8</div>
            <div class="mt-1 text-xs text-ink-400 sm:text-sm">{t('hero.statLanguages')}</div>
          </div>
        </div>
      </div>

      <!-- Hero Illustration -->
      <div class="animate-fade-in animation-delay-500 mt-12 mx-auto max-w-2xl">
        <img
          src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=modern%20futuristic%20AI%20health%20technology%20concept%2C%20glowing%20medical%20cross%20symbol%20merged%20with%20digital%20neural%20network%20patterns%2C%20blue%20and%20teal%20gradient%20color%20scheme%2C%20clean%20minimal%3B%20white%20background%2C%20professional%20medical%20tech%20illustration%2C%20high%20quality%203D%20render&image_size=landscape_16_9"
          alt="SynoChain AI - AI-powered health companion"
          class="w-full rounded-2xl border border-ink-100 shadow-xl"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
