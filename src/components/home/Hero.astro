---
import { useTranslations, type Lang } from '../../i18n/ui';
import { getCrowdfundingStats, defaultStats } from '../../lib/supabase';
import { formatCurrency, formatNumber } from '../../lib/utils';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const stats = await getCrowdfundingStats();
const progressPercent = Math.min((stats.total_raised / stats.goal) * 100, 100);
---

<section class="relative overflow-hidden bg-white pt-32 pb-20 md:pt-40 md:pb-32">
  <!-- 背景网格 -->
  <div class="absolute inset-0 grid-bg opacity-60"></div>

  <!-- 背景光晕 -->
  <div class="absolute left-1/2 top-0 -z-10 h-[600px] w-[600px] -translate-x-1/2 rounded-full bg-medical-100/40 blur-3xl"></div>
  <div class="absolute right-0 top-40 -z-10 h-[400px] w-[400px] rounded-full bg-health-100/30 blur-3xl"></div>

  <div class="container-x relative">
    <div class="mx-auto max-w-4xl text-center">
      <!-- 标签 -->
      <div class="animate-fade-in mb-6 inline-flex items-center gap-2 rounded-full border border-medical-200 bg-medical-50 px-4 py-1.5 text-xs font-medium text-medical-700">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-health-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-health-500"></span>
        </span>
        Community-Funded AI Health Project
      </div>

      <!-- 主标题 -->
      <h1 class="animate-slide-up text-4xl font-extrabold leading-tight tracking-tight text-ink-800 sm:text-5xl md:text-6xl lg:text-7xl">
        Build The World's First
        <span class="gradient-text block sm:inline">AI Health Companion</span>
        Together
      </h1>

      <!-- 副标题 -->
      <p class="animate-slide-up animation-delay-200 mx-auto mt-6 max-w-2xl text-base leading-relaxed text-ink-500 sm:text-lg md:text-xl">
        Join our community-funded AI health project. Your contribution helps us build AI models, train medical knowledge systems, develop apps, and make personalized health guidance accessible to everyone.
      </p>

      <!-- CTA 按钮 -->
      <div class="animate-slide-up animation-delay-300 mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="#founder" class="btn-primary w-full sm:w-auto">
          <span class="text-base">🚀</span>
          {t('hero.cta')}
        </a>
        <a href="#ai-assistant" class="btn-secondary w-full sm:w-auto">
          {t('home.tryAssistant')}
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- 众筹进度 -->
      <div class="animate-slide-up animation-delay-400 mt-16 mx-auto max-w-3xl">
        <div class="rounded-2xl border border-ink-100 bg-white/80 p-6 shadow-sm backdrop-blur sm:p-8">
          <!-- 进度条 -->
          <div class="mb-6">
            <div class="mb-2 flex items-center justify-between text-sm">
              <span class="font-medium text-ink-700">{formatCurrency(stats.total_raised)} {t('hero.raised')}</span>
              <span class="text-ink-400">of {formatCurrency(stats.goal)} goal</span>
            </div>
            <div class="h-3 w-full overflow-hidden rounded-full bg-ink-100">
              <div
                class="h-full rounded-full bg-gradient-to-r from-medical-500 to-health-500 transition-all duration-1000"
                style={`width: ${progressPercent}%`}
              ></div>
            </div>
          </div>

          <!-- 统计数据 -->
          <div class="grid grid-cols-3 gap-4 sm:gap-8">
            <div class="text-center">
              <div class="font-display text-2xl font-bold text-medical-600 sm:text-3xl">
                {formatCurrency(stats.total_raised)}
              </div>
              <div class="mt-1 text-xs text-ink-400 sm:text-sm">{t('hero.raised')}</div>
            </div>
            <div class="border-x border-ink-100 text-center">
              <div class="font-display text-2xl font-bold text-health-600 sm:text-3xl">
                {formatNumber(stats.supporter_count)}
              </div>
              <div class="mt-1 text-xs text-ink-400 sm:text-sm">{t('hero.supporters')}</div>
            </div>
            <div class="text-center">
              <div class="font-display text-2xl font-bold text-ink-800 sm:text-3xl">
                {stats.days_remaining}
              </div>
              <div class="mt-1 text-xs text-ink-400 sm:text-sm">{t('hero.daysRemaining')}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
