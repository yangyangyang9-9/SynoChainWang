<script>
  // 复制钱包地址
  const copyBtn = document.getElementById('copy-wallet-btn');
  const copyText = document.getElementById('copy-text');
  const walletAddress = document.getElementById('wallet-address');

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(walletAddress?.textContent || '');
      if (copyText) {
        copyText.textContent = 'Copied!';
        copyBtn.classList.add('bg-health-500');
        copyBtn.classList.remove('bg-medical-500');
        setTimeout(() => {
          copyText.textContent = 'Copy';
          copyBtn.classList.remove('bg-health-500');
          copyBtn.classList.add('bg-medical-500');
        }, 2000);
      }
    } catch (err) {
      console.error('Failed to copy:', err);
    }
  });
</script>
