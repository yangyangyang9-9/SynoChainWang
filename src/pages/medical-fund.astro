---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const COMPANY_EMAIL = 'yuzhouyixue@gmail.com';

// 示例病人数据
const patients = [
  {
    name: 'Sarah M.',
    age: 34,
    condition: 'Stage III Breast Cancer',
    location: 'New York, USA',
    walletAddress: '0x7859887393f998d118073aeeEaA68DCb8Bf349d4',
    videoThumbnail: 'https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=a%20brave%20young%20woman%20smiling%20warmly%20in%20a%20hospital%20garden%2C%20soft%20natural%20lighting%2C%20hopeful%20mood%2C%20documentary%20style%20photo&image_size=landscape_4_3',
    raised: 18450,
    goal: 50000,
    story: 'Sarah was diagnosed with stage III breast cancer last year. She needs funding for immunotherapy treatment not covered by her insurance.',
    daysLeft: 23,
  },
  {
    name: 'Michael R.',
    age: 52,
    condition: 'Cardiac Surgery',
    location: 'London, UK',
    walletAddress: '0x4F7A8c9eB2D1e3F5a6C7d8E9f0A1b2C3d4E5f6A7',
    videoThumbnail: 'https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=a%20middle%20aged%20man%20with%20kind%20eyes%20sitting%20in%20a%20cozy%20living%20room%2C%20warm%20lighting%2C%20documentary%20photo%20style&image_size=landscape_4_3',
    raised: 32000,
    goal: 80000,
    story: 'Michael requires a complex heart valve replacement surgery. As a father of three, he is fighting to be there for his family.',
    daysLeft: 15,
  },
  {
    name: 'Lily C.',
    age: 7,
    condition: 'Leukemia Treatment',
    location: 'Toronto, Canada',
    walletAddress: '0x8B3e9D2c1A4b5E6f7C8d9E0f1A2b3C4d5E6f7A8b',
    videoThumbnail: 'https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=a%20courageous%20little%20girl%20with%20a%20bright%20smile%20holding%20a%20stuffed%20animal%20in%20a%20hospital%2C%20soft%20warm%20lighting%2C%20hopeful%20documentary%20photo&image_size=landscape_4_3',
    raised: 45200,
    goal: 120000,
    story: 'Little Lily is battling acute lymphoblastic leukemia. Her family needs help covering the cost of a bone marrow transplant.',
    daysLeft: 40,
  },
  {
    name: 'David K.',
    age: 45,
    condition: 'Liver Transplant',
    location: 'Sydney, Australia',
    walletAddress: '0x2C5f7A9b3E1d4C6e8F0a1B2c3D4e5F6a7B8c9D0e',
    videoThumbnail: 'https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=a%20resilient%20man%20in%20his%20forties%20standing%20by%20the%20ocean%2C%20contemplative%20expression%2C%20warm%20golden%20hour%20lighting%2C%20documentary%20photo%20style&image_size=landscape_4_3',
    raised: 9800,
    goal: 150000,
    story: 'David has been on the transplant waiting list for 18 months. He needs urgent help with transplant surgery and post-operative care.',
    daysLeft: 60,
  },
  {
    name: 'Aisha T.',
    age: 28,
    condition: 'Brain Tumor Surgery',
    location: 'Dubai, UAE',
    walletAddress: '0x6E1a4F8c2B7d5E9f3A6b1C4d8E0f2A5b7C9d1E3f',
    videoThumbnail: 'https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=a%20brave%20young%20woman%20with%20a%20headscarf%20smiling%20gently%20in%20a%20modern%20hospital%20corridor%2C%20soft%20natural%20light%2C%20documentary%20photo%20style&image_size=landscape_4_3',
    raised: 27300,
    goal: 95000,
    story: 'Aisha was diagnosed with a benign brain tumor that requires delicate surgery. She dreams of returning to her teaching career.',
    daysLeft: 30,
  },
  {
    name: 'James W.',
    age: 61,
    condition: 'Kidney Dialysis & Transplant',
    location: 'Chicago, USA',
    walletAddress: '0x9D2e5A8c3F6b1E4d7C0a9B3c5D8e1F4a6B7c0E2d',
    videoThumbnail: 'https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=a%20dignified%20older%20man%20with%20grey%20hair%20sitting%20in%20a%20sunlit%20room%2C%20peaceful%20expression%2C%20warm%20documentary%20photo%20style&image_size=landscape_4_3',
    raised: 15600,
    goal: 70000,
    story: 'James has been on dialysis for 3 years. A kidney transplant would give him a second chance at life with his grandchildren.',
    daysLeft: 45,
  },
];
---

<BaseLayout title="Medical Treatment Fund - SynoChain AI" description="Support patients battling major illnesses. Donate crypto to help fund life-saving treatments. 100% of funds go directly to patient care." lang={lang}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-white pt-32 pb-16">
    <div class="absolute inset-0 grid-bg opacity-40"></div>
    <div class="absolute left-1/2 top-0 -z-10 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-medical-100/30 blur-3xl"></div>
    <div class="absolute right-0 top-40 -z-10 h-[400px] w-[400px] rounded-full bg-health-100/20 blur-3xl"></div>

    <div class="container-x relative">
      <div class="mx-auto max-w-3xl text-center">
        <span class="inline-block rounded-full bg-health-50 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-health-700">
          {t('medicalFund.badge')}
        </span>
        <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-ink-800 sm:text-5xl md:text-6xl">
          {t('medicalFund.title')}
        </h1>
        <p class="mt-6 text-base text-ink-500 sm:text-lg">
          {t('medicalFund.subtitle')}
        </p>

        <!-- 统计 -->
        <div class="mx-auto mt-10 grid max-w-2xl grid-cols-3 gap-4">
          <div class="rounded-2xl border border-ink-100 bg-white/80 p-4 shadow-sm backdrop-blur">
            <div class="font-display text-2xl font-bold text-medical-600 sm:text-3xl">$148K+</div>
            <div class="mt-1 text-xs text-ink-400">{t('medicalFund.totalRaised')}</div>
          </div>
          <div class="rounded-2xl border border-ink-100 bg-white/80 p-4 shadow-sm backdrop-blur">
            <div class="font-display text-2xl font-bold text-health-600 sm:text-3xl">6</div>
            <div class="mt-1 text-xs text-ink-400">{t('medicalFund.activePatients')}</div>
          </div>
          <div class="rounded-2xl border border-ink-100 bg-white/80 p-4 shadow-sm backdrop-blur">
            <div class="font-display text-2xl font-bold text-ink-800 sm:text-3xl">100%</div>
            <div class="mt-1 text-xs text-ink-400">{t('medicalFund.toTreatment')}</div>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="#donate" class="btn-primary w-full sm:w-auto">
            <span>💝</span> {t('medicalFund.donateNow')}
          </a>
          <a href="#patients" class="btn-secondary w-full sm:w-auto">
            {t('medicalFund.viewStories')}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 病人故事 -->
  <section id="patients" class="section-padding bg-ink-50">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <span class="inline-block rounded-full bg-health-50 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-health-700">
          {t('medicalFund.storiesBadge')}
        </span>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-ink-800 sm:text-4xl">
          {t('medicalFund.storiesTitle')}
        </h2>
        <p class="mt-4 text-base text-ink-500 sm:text-lg">
          {t('medicalFund.storiesSubtitle')}
        </p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {patients.map((patient) => {
          const progress = Math.min((patient.raised / patient.goal) * 100, 100);
          return (
            <div class="group overflow-hidden rounded-2xl border border-ink-100 bg-white shadow-sm transition-all hover:shadow-xl">
              <!-- 视频缩略图 -->
              <div class="relative aspect-video overflow-hidden">
                <img
                  src={patient.videoThumbnail}
                  alt={patient.name}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                <!-- 播放按钮 -->
                <div class="absolute inset-0 flex items-center justify-center bg-black/30 transition-opacity group-hover:bg-black/40">
                  <div class="flex h-16 w-16 items-center justify-center rounded-full bg-white/90 shadow-lg transition-transform group-hover:scale-110">
                    <svg class="ml-1 h-7 w-7 text-medical-600" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
                <!-- 疾病标签 -->
                <div class="absolute left-3 top-3">
                  <span class="rounded-full bg-medical-500/90 px-3 py-1 text-xs font-semibold text-white backdrop-blur">
                    {patient.condition}
                  </span>
                </div>
                <!-- 剩余天数 -->
                <div class="absolute right-3 top-3">
                  <span class="rounded-full bg-black/60 px-3 py-1 text-xs font-medium text-white backdrop-blur">
                    {patient.daysLeft} {t('medicalFund.daysLeft')}
                  </span>
                </div>
              </div>

              <!-- 内容 -->
              <div class="p-6">
                <div class="flex items-center gap-2">
                  <h3 class="font-display text-lg font-bold text-ink-800">{patient.name}</h3>
                  <span class="text-sm text-ink-400">· {patient.age} yrs</span>
                </div>
                <p class="mt-1 text-xs text-ink-400">📍 {patient.location}</p>
                <p class="mt-3 text-sm leading-relaxed text-ink-600 line-clamp-3">{patient.story}</p>

                <!-- 筹款进度 -->
                <div class="mt-4">
                  <div class="mb-2 flex items-center justify-between text-sm">
                    <span class="font-semibold text-medical-600">${patient.raised.toLocaleString()}</span>
                    <span class="text-ink-400">of ${patient.goal.toLocaleString()}</span>
                  </div>
                  <div class="h-2.5 w-full overflow-hidden rounded-full bg-ink-100">
                    <div
                      class="h-full rounded-full bg-gradient-to-r from-medical-500 to-health-500"
                      style={`width: ${progress}%`}
                    ></div>
                  </div>
                </div>

                <!-- 捐款钱包地址 -->
                <div class="mt-5 rounded-xl border-2 border-dashed border-medical-200 bg-medical-50/30 p-3">
                  <p class="text-xs font-medium text-ink-400">{t('medicalFund.donateTo')}: {patient.name}</p>
                  <div class="mt-2 flex items-center gap-2">
                    <code class="flex-1 truncate font-mono text-xs text-ink-700" data-wallet={patient.walletAddress}>
                      {patient.walletAddress}
                    </code>
                    <button class="copy-wallet-btn flex-shrink-0 rounded-lg bg-medical-500 px-3 py-1.5 text-xs font-semibold text-white hover:bg-medical-600" data-address={patient.walletAddress} data-copy-text={t('medicalFund.copy')} data-copied-text={t('medicalFund.copied')}>
                      {t('medicalFund.copy')}
                    </button>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 钱包捐款 -->
  <section id="donate" class="section-padding bg-white">
    <div class="container-x">
      <div class="mx-auto max-w-3xl">
        <div class="text-center">
          <span class="inline-block rounded-full bg-medical-50 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-medical-700">
            {t('medicalFund.donateBadge')}
          </span>
          <h2 class="mt-4 text-3xl font-bold tracking-tight text-ink-800 sm:text-4xl">
            {t('medicalFund.donateTitle')}
          </h2>
          <p class="mt-4 text-base text-ink-500 sm:text-lg">
            {t('medicalFund.donateSubtitle')}
          </p>
        </div>

        <!-- 信息卡片 -->
        <div class="mx-auto mt-12 max-w-2xl">
          <div class="relative overflow-hidden rounded-3xl border-2 border-medical-200 bg-gradient-to-br from-medical-50 via-white to-health-50 p-8 shadow-xl">
            <!-- 装饰背景 -->
            <div class="absolute -right-20 -top-20 h-40 w-40 rounded-full bg-medical-200/30 blur-3xl"></div>
            <div class="absolute -bottom-20 -left-20 h-40 w-40 rounded-full bg-health-200/30 blur-3xl"></div>

            <div class="relative">
              <div class="flex items-center gap-3">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-medical-500 to-health-500 shadow-lg">
                  <svg class="h-6 w-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 8V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-1" />
                    <path d="M16 12h6" />
                    <path d="M19 9v6" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-display text-lg font-bold text-ink-800">{t('medicalFund.walletLabel')}</h3>
                  <p class="text-xs text-ink-500">{t('medicalFund.walletType')}</p>
                </div>
              </div>

              <!-- 说明 -->
              <div class="mt-6">
                <div class="rounded-xl border-2 border-dashed border-medical-300 bg-white/80 p-4">
                  <p class="text-sm font-medium text-ink-800">{t('medicalFund.walletHint')}</p>
                  <p class="mt-1 text-xs text-ink-500">
                    {t('medicalFund.donateSubtitle')}
                  </p>
                </div>
              </div>

              <!-- 支持的代币 -->
              <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
                <div class="rounded-xl border border-ink-100 bg-white p-3 text-center">
                  <div class="text-lg font-bold text-ink-800">ETH</div>
                  <div class="text-xs text-ink-400">Ethereum</div>
                </div>
                <div class="rounded-xl border border-ink-100 bg-white p-3 text-center">
                  <div class="text-lg font-bold text-ink-800">USDT</div>
                  <div class="text-xs text-ink-400">Tether</div>
                </div>
                <div class="rounded-xl border border-ink-100 bg-white p-3 text-center">
                  <div class="text-lg font-bold text-ink-800">USDC</div>
                  <div class="text-xs text-ink-400">USD Coin</div>
                </div>
                <div class="rounded-xl border border-ink-100 bg-white p-3 text-center">
                  <div class="text-lg font-bold text-ink-800">BTC</div>
                  <div class="text-xs text-ink-400">Bitcoin</div>
                </div>
              </div>

              <!-- 安全提示 -->
              <div class="mt-6 flex items-start gap-2 rounded-xl bg-health-50 p-4">
                <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-health-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  <path d="M9 12l2 2 4-4" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-health-800">{t('medicalFund.verifiedSecure')}</p>
                  <p class="mt-1 text-xs text-health-700">
                    {t('medicalFund.verifiedDesc')}
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 捐款后联系 -->
        <div class="mx-auto mt-8 max-w-2xl rounded-2xl border border-ink-100 bg-ink-50 p-6 text-center">
          <p class="text-sm text-ink-600" set:html={t('medicalFund.afterDonating').replace('our company email', `<a href="mailto:${COMPANY_EMAIL}" class="font-semibold text-medical-600 underline hover:text-medical-700">${COMPANY_EMAIL}</a>`)}>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 流程说明 -->
  <section class="section-padding bg-ink-50">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <span class="inline-block rounded-full bg-health-50 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-health-700">
          {t('medicalFund.howItWorksBadge')}
        </span>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-ink-800 sm:text-4xl">
          {t('medicalFund.howItWorksTitle')}
        </h2>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl gap-8 md:grid-cols-2 lg:grid-cols-4">
        <!-- Step 1 -->
        <div class="relative rounded-2xl border border-ink-100 bg-white p-6 text-center shadow-sm">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-medical-50 text-2xl">📹</div>
          <h3 class="mt-4 font-display text-base font-bold text-ink-800">{t('medicalFund.step1Title')}</h3>
          <p class="mt-2 text-xs leading-relaxed text-ink-500">
            {t('medicalFund.step1Desc')}
          </p>
          <div class="mt-3 rounded-lg bg-medical-50 p-2">
            <p class="text-xs font-medium text-medical-700">📧 {COMPANY_EMAIL}</p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative rounded-2xl border border-ink-100 bg-white p-6 text-center shadow-sm">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-health-50 text-2xl">✅</div>
          <h3 class="mt-4 font-display text-base font-bold text-ink-800">{t('medicalFund.step2Title')}</h3>
          <p class="mt-2 text-xs leading-relaxed text-ink-500">
            {t('medicalFund.step2Desc')}
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative rounded-2xl border border-ink-100 bg-white p-6 text-center shadow-sm">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-medical-50 text-2xl">🤝</div>
          <h3 class="mt-4 font-display text-base font-bold text-ink-800">{t('medicalFund.step3Title')}</h3>
          <p class="mt-2 text-xs leading-relaxed text-ink-500">
            {t('medicalFund.step3Desc')}
          </p>
        </div>

        <!-- Step 4 -->
        <div class="relative rounded-2xl border border-ink-100 bg-white p-6 text-center shadow-sm">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-health-50 text-2xl">🏥</div>
          <h3 class="mt-4 font-display text-base font-bold text-ink-800">{t('medicalFund.step4Title')}</h3>
          <p class="mt-2 text-xs leading-relaxed text-ink-500">
            {t('medicalFund.step4Desc')}
          </p>
        </div>
      </div>

      <!-- 连接线说明 -->
      <div class="mx-auto mt-12 max-w-3xl rounded-2xl border border-health-200 bg-health-50 p-6 text-center">
        <div class="flex items-center justify-center gap-2 text-health-700">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
          <p class="text-sm font-medium">
            {t('medicalFund.importantNote')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 成为筹款人 -->
  <section class="section-padding bg-white">
    <div class="container-x">
      <div class="mx-auto max-w-3xl">
        <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-medical-600 via-medical-500 to-health-500 p-8 shadow-2xl sm:p-12">
          <div class="absolute -right-20 -top-20 h-60 w-60 rounded-full bg-white/10 blur-3xl"></div>
          <div class="absolute -bottom-20 -left-20 h-60 w-60 rounded-full bg-white/10 blur-3xl"></div>

          <div class="relative text-center">
            <h2 class="text-3xl font-bold text-white sm:text-4xl">
              {t('medicalFund.applyTitle')}
            </h2>
            <p class="mt-4 text-base text-white/90 sm:text-lg">
              {t('medicalFund.applySubtitle')}
            </p>

            <div class="mx-auto mt-8 max-w-xl rounded-2xl bg-white/15 p-6 backdrop-blur">
              <h3 class="font-display text-lg font-bold text-white">{t('medicalFund.applyStepsTitle')}</h3>
              <ol class="mt-4 space-y-3 text-left">
                <li class="flex items-start gap-3">
                  <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-white text-sm font-bold text-medical-600">1</span>
                  <span class="text-sm text-white/90">{t('medicalFund.applyStep1')}</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-white text-sm font-bold text-medical-600">2</span>
                  <span class="text-sm text-white/90">{t('medicalFund.applyStep2')}</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-white text-sm font-bold text-medical-600">3</span>
                  <span class="text-sm text-white/90">{t('medicalFund.applyStep3')}</span>
                </li>
              </ol>
            </div>

            <a
              href={`mailto:${COMPANY_EMAIL}?subject=Medical Fund Application&body=I would like to apply for the medical treatment fund.%0D%0A%0D%0APatient Name:%0D%0ACondition:%0D%0ATreatment Needed:%0D%0AEstimated Cost:%0D%0AContact Information:`}
              class="mt-8 inline-flex items-center gap-2 rounded-xl bg-white px-8 py-4 text-sm font-bold text-medical-600 shadow-lg transition-transform hover:scale-105"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              {t('medicalFund.applyBtn')}
            </a>
            <p class="mt-3 text-xs text-white/70">{COMPANY_EMAIL}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-padding bg-ink-50">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-ink-800 sm:text-4xl">{t('medicalFund.faqTitle')}</h2>
      </div>
      <div class="mx-auto mt-12 max-w-3xl space-y-4">
        <details class="group rounded-xl border border-ink-100 bg-white p-6 shadow-sm" open>
