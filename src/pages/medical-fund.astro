<script>
  // 复制钱包地址
  document.querySelectorAll('.copy-wallet-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const address = btn.getAttribute('data-address');
      try {
        await navigator.clipboard.writeText(address || '');
        const originalText = btn.textContent;
        btn.textContent = btn.getAttribute('data-copied-text') || 'Copied!';
        btn.classList.add('bg-health-500');
        btn.classList.remove('bg-medical-500');
        setTimeout(() => {
          btn.textContent = btn.getAttribute('data-copy-text') || 'Copy';
          btn.classList.remove('bg-health-500');
          btn.classList.add('bg-medical-500');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    });
  });
</script>
