---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';
import { formatDate } from '../../lib/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// 根据语言生成基础路径
const basePath = lang === 'en' ? '' : `/${lang}`;

// 博客文章 mock 数据
const posts = [
  {
    slug: 'understanding-ai-in-healthcare',
    title: 'Understanding AI in Healthcare: A Complete Guide',
    excerpt: 'Explore how artificial intelligence is transforming medical diagnosis, treatment planning, and personalized patient care in 2026.',
    category: 'AI & Technology',
    date: '2026-06-28',
    readTime: '8 min read',
    author: 'Dr. Sarah Chen',
    cover: 'from-medical-400 to-medical-600',
  },
  {
    slug: 'natural-remedies-for-better-sleep',
    title: '10 Natural Remedies for Better Sleep Tonight',
    excerpt: 'Discover evidence-based natural approaches to improve sleep quality, from herbal teas to sleep hygiene practices.',
    category: 'Natural Health',
    date: '2026-06-22',
    readTime: '6 min read',
    author: 'Dr. James Liu',
    cover: 'from-health-400 to-health-600',
  },
  {
    slug: 'nutrition-guide-chronic-inflammation',
    title: 'A Nutrition Guide to Fighting Chronic Inflammation',
    excerpt: 'Learn which foods reduce inflammation and which to avoid, with a practical 7-day anti-inflammatory meal plan.',
    category: 'Nutrition',
    date: '2026-06-15',
    readTime: '10 min read',
    author: 'Nutritionist Maya Patel',
    cover: 'from-medical-500 to-health-500',
  },
  {
    slug: 'managing-anxiety-naturally',
    title: 'Managing Anxiety: Evidence-Based Natural Approaches',
    excerpt: 'From mindfulness meditation to breathing exercises, explore proven strategies to reduce anxiety without medication.',
    category: 'Mental Health',
    date: '2026-06-08',
    readTime: '7 min read',
    author: 'Dr. Emily Roberts',
    cover: 'from-ink-400 to-medical-500',
  },
  {
    slug: 'understanding-blood-pressure',
    title: 'Understanding Your Blood Pressure Numbers',
    excerpt: 'What do those two numbers really mean? A cardiologist breaks down blood pressure readings and what they reveal about your health.',
    category: 'Cardiology',
    date: '2026-05-30',
    readTime: '5 min read',
    author: 'Dr. Michael Wong',
    cover: 'from-medical-600 to-ink-700',
  },
  {
    slug: 'gut-health-and-immunity',
    title: 'The Gut-Immunity Connection: What Science Says',
    excerpt: 'Recent research reveals how your gut microbiome influences immune function and overall health. Here\'s what you need to know.',
    category: 'Research',
    date: '2026-05-21',
    readTime: '9 min read',
    author: 'Dr. Anna Kim',
    cover: 'from-health-500 to-medical-600',
  },
];

// 分类筛选标签
const categories = ['All', ...new Set(posts.map((p) => p.category))];
---

<BaseLayout
  title="Health Blog & Research - SynoChain AI"
  description="Read the latest health articles, medical research insights, and wellness tips from healthcare professionals. Topics include AI in medicine, nutrition, mental health, and natural remedies."
  lang={lang}
>
  <!-- 页面顶部 Hero -->
  <section class="relative overflow-hidden bg-white pt-32 pb-12">
    <div class="absolute inset-0 grid-bg opacity-40"></div>
    <div class="container-x relative">
      <div class="mx-auto max-w-3xl text-center">
        <span class="inline-flex items-center gap-2 rounded-full border border-medical-200 bg-medical-50 px-4 py-1.5 text-xs font-medium text-medical-700">
          <span class="text-base">📰</span>
          Health Insights & Research
        </span>
        <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-ink-800 sm:text-5xl">
          Blog & Research
        </h1>
        <p class="mt-4 text-base text-ink-500 sm:text-lg">
          Expert articles on health, wellness, AI in medicine, and the latest medical research insights.
        </p>
      </div>
    </div>
  </section>

  <!-- 分类筛选标签 -->
  <section class="bg-white pb-8">
    <div class="container-x">
      <div class="flex flex-wrap items-center justify-center gap-2">
        {categories.map((cat, index) => (
          <button
            class:list={[
              'rounded-full px-4 py-2 text-sm font-medium transition-colors',
              index === 0
                ? 'bg-medical-500 text-white'
                : 'bg-ink-50 text-ink-600 hover:bg-medical-50 hover:text-medical-700',
            ]}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- 文章卡片网格 -->
  <section class="bg-white section-padding pt-8">
    <div class="container-x">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <article class="group flex flex-col overflow-hidden rounded-2xl border border-ink-100 bg-white shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg hover:border-medical-100">
            <!-- 封面图占位 -->
            <a href={`${basePath}/blog/${post.slug}`} class={`relative block h-48 bg-gradient-to-br ${post.cover}`}>
              <div class="absolute inset-0 flex items-center justify-center text-6xl opacity-30">
                📄
              </div>
              <span class="absolute left-4 top-4 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-ink-700 backdrop-blur">
                {post.category}
              </span>
            </a>

            <!-- 内容 -->
            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-center gap-3 text-xs text-ink-400">
                <span>{formatDate(post.date)}</span>
                <span>•</span>
                <span>{post.readTime}</span>
              </div>
              <h2 class="mt-3 font-display text-lg font-bold leading-snug text-ink-800 group-hover:text-medical-600">
                <a href={`${basePath}/blog/${post.slug}`}>{post.title}</a>
              </h2>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-500">
                {post.excerpt}
              </p>

              <!-- 作者与阅读链接 -->
              <div class="mt-5 flex items-center justify-between border-t border-ink-100 pt-4">
                <div class="flex items-center gap-2">
                  <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-medical-400 to-health-400 text-xs font-bold text-white">
                    {post.author.split(' ').map((n) => n[0]).join('').slice(0, 2)}
                  </div>
                  <span class="text-xs font-medium text-ink-600">{post.author}</span>
                </div>
                <a
                  href={`${basePath}/blog/${post.slug}`}
                  class="flex items-center gap-1 text-xs font-semibold text-medical-600"
                >
                  Read More
                  <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- 医疗免责声明 -->
      <div class="mx-auto mt-16 max-w-3xl border-t border-ink-100 pt-6">
        <p class="text-center text-xs leading-relaxed text-ink-400">
          ⚠️ Medical Disclaimer: Articles on this blog are for informational and educational purposes only and do not constitute medical advice. Always consult a qualified healthcare professional before making decisions about your health or treatment.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
