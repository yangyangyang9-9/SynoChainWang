---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentPage from '../../components/ContentPage.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';
import topics from '../../data/mental-health.json';

export async function getStaticPaths() {
  return topics.map(topic => ({
    params: { slug: topic.slug },
  }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { slug } = Astro.params;
const topic = topics.find(t => t.slug === slug);

if (!topic) {
  return Astro.redirect('/mental-health', 301);
}

const contentData = {
  title: topic.name,
  metaDescription: topic.meta_description,
  lang,
  type: 'mental_health' as const,
  overview: topic.description,
  quickFacts: { Category: topic.category },
  commonSymptoms: topic.symptoms,
  possibleCauses: topic.types,
  diagnosis: topic.causes,
  lifestyleTips: topic.coping_strategies,
  relatedConditions: topic.related_conditions || [],
  relatedQuestions: topic.related_questions || [],
  relatedTools: topic.related_tools || [],
  t,
};
---

<BaseLayout
  title={`${contentData.title} - ${t('nav.mentalHealth')} - SynoChain AI`}
  description={contentData.metaDescription}
  lang={lang}
>
  <ContentPage {...contentData} />
</BaseLayout>
