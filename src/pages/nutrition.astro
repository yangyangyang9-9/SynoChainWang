---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// 根据语言生成基础路径
const basePath = lang === 'en' ? '' : `/${lang}`;

// 营养素分类 mock 数据
const nutrients = [
  {
    name: 'Vitamin C',
    icon: '🍊',
    category: 'Vitamin',
    color: 'from-orange-400 to-amber-500',
    benefits: 'Immune support, collagen production, antioxidant protection',
    dailyValue: '75-90 mg',
    foods: ['Citrus fruits', 'Strawberries', 'Bell peppers', 'Broccoli', 'Kiwi'],
  },
  {
    name: 'Vitamin D',
    icon: '☀️',
    category: 'Vitamin',
    color: 'from-yellow-400 to-orange-500',
    benefits: 'Bone health, immune function, mood regulation',
    dailyValue: '600-800 IU',
    foods: ['Fatty fish', 'Egg yolks', 'Fortified milk', 'Mushrooms', 'Sunlight'],
  },
  {
    name: 'Vitamin B12',
    icon: '💊',
    category: 'Vitamin',
    color: 'from-medical-400 to-medical-600',
    benefits: 'Nerve function, red blood cell formation, DNA synthesis',
    dailyValue: '2.4 mcg',
    foods: ['Meat', 'Fish', 'Eggs', 'Dairy', 'Fortified cereals'],
  },
  {
    name: 'Iron',
    icon: '🩸',
    category: 'Mineral',
    color: 'from-red-400 to-rose-500',
    benefits: 'Oxygen transport, energy production, immune function',
    dailyValue: '8-18 mg',
    foods: ['Red meat', 'Spinach', 'Lentils', 'Pumpkin seeds', 'Fortified grains'],
  },
  {
    name: 'Calcium',
    icon: '🦴',
    category: 'Mineral',
    color: 'from-ink-300 to-ink-500',
    benefits: 'Bone and teeth health, muscle function, nerve signaling',
    dailyValue: '1000-1200 mg',
    foods: ['Dairy products', 'Leafy greens', 'Sardines', 'Tofu', 'Almonds'],
  },
  {
    name: 'Magnesium',
    icon: '🌱',
    category: 'Mineral',
    color: 'from-health-400 to-health-600',
    benefits: 'Muscle and nerve function, blood sugar, blood pressure',
    dailyValue: '310-420 mg',
    foods: ['Nuts', 'Seeds', 'Whole grains', 'Leafy greens', 'Dark chocolate'],
  },
  {
    name: 'Omega-3',
    icon: '🐟',
    category: 'Fatty Acid',
    color: 'from-medical-500 to-health-500',
    benefits: 'Heart health, brain function, inflammation reduction',
    dailyValue: '250-500 mg',
    foods: ['Salmon', 'Sardines', 'Walnuts', 'Flaxseeds', 'Chia seeds'],
  },
  {
    name: 'Zinc',
    icon: '🛡️',
    category: 'Mineral',
    color: 'from-purple-400 to-indigo-500',
    benefits: 'Immune function, wound healing, protein synthesis',
    dailyValue: '8-11 mg',
    foods: ['Oysters', 'Beef', 'Pumpkin seeds', 'Chickpeas', 'Cashews'],
  },
];

// 食物推荐
const foodGroups = [
  { name: 'Fruits & Vegetables', icon: '🥬', items: 'Aim for 5+ servings daily. Color variety ensures diverse nutrients.', count: '5+ servings' },
  { name: 'Whole Grains', icon: '🌾', items: 'Brown rice, oats, quinoa, whole wheat. Rich in fiber and B vitamins.', count: '3+ servings' },
  { name: 'Lean Proteins', icon: '🍗', items: 'Fish, poultry, beans, tofu. Essential for muscle and tissue repair.', count: '2-3 servings' },
  { name: 'Healthy Fats', icon: '🥑', items: 'Avocado, olive oil, nuts, seeds. Support heart and brain health.', count: '2-3 servings' },
];

// 饮食方案
const dietPlans = [
  {
    name: 'Mediterranean Diet',
    icon: '🫒',
    focus: 'Heart health & longevity',
    desc: 'Rich in olive oil, fish, vegetables, and whole grains. Linked to reduced cardiovascular disease risk.',
    badge: 'Most Popular',
  },
  {
    name: 'DASH Diet',
    icon: '❤️',
    focus: 'Blood pressure control',
    desc: 'Low sodium, high potassium, calcium, and magnesium. Designed to lower hypertension.',
    badge: 'Heart Healthy',
  },
  {
    name: 'Anti-Inflammatory Diet',
    icon: '🌿',
    focus: 'Reduce inflammation',
    desc: 'Emphasizes antioxidants and omega-3s while limiting processed foods and refined sugars.',
    badge: 'Wellness',
  },
  {
    name: 'Plant-Based Diet',
    icon: '🥗',
    focus: 'Overall wellness',
    desc: 'Focuses on whole plant foods. Associated with lower risk of chronic diseases.',
    badge: 'Sustainable',
  },
];
---

<BaseLayout
  title="Nutrition Guide - Vitamins, Minerals & Diet Plans | SynoChain AI"
  description="Comprehensive nutrition guide covering essential vitamins, minerals, food recommendations, and evidence-based diet plans for optimal health."
  lang={lang}
>
  <!-- 页面顶部 Hero -->
  <section class="relative overflow-hidden bg-white pt-32 pb-16">
    <div class="absolute inset-0 grid-bg opacity-40"></div>
    <div class="container-x relative">
      <div class="mx-auto max-w-3xl text-center">
        <span class="inline-flex items-center gap-2 rounded-full border border-health-200 bg-health-50 px-4 py-1.5 text-xs font-medium text-health-700">
          <span class="text-base">🥗</span>
          {t('tools.nutrition.title')}
        </span>
        <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-ink-800 sm:text-5xl">
          Nutrition Guide
        </h1>
        <p class="mt-4 text-base text-ink-500 sm:text-lg">
          Understand essential nutrients, discover healthy foods, and explore evidence-based diet plans tailored to your health goals.
        </p>
        <div class="mt-8 mx-auto max-w-xl">
          <img
            src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=healthy%20nutrition%20and%20diet%20concept%2C%20fresh%20fruits%20vegetables%20supplements%2C%20clean%20modern%20illustration%2C%20blue%20teal%20gradient&image_size=landscape_16_9"
            alt="Nutrition Guide"
            class="w-full rounded-2xl border border-ink-100 shadow-lg"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 营养素卡片 -->
  <section class="bg-white section-padding pt-8">
    <div class="container-x">
      <h2 class="text-2xl font-bold text-ink-800 sm:text-3xl">Essential Nutrients</h2>
      <p class="mt-3 text-ink-500">Key vitamins and minerals your body needs to function optimally.</p>

      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {nutrients.map((nutrient) => (
          <div class="card group">
            <div class={`flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br ${nutrient.color} text-3xl shadow-sm`}>
              {nutrient.icon}
            </div>
            <div class="mt-4 flex items-center justify-between">
              <h3 class="font-display font-bold text-ink-800 group-hover:text-medical-600">{nutrient.name}</h3>
              <span class="rounded-full bg-ink-50 px-2.5 py-0.5 text-xs font-medium text-ink-500">{nutrient.category}</span>
            </div>
            <p class="mt-2 text-sm text-ink-500">{nutrient.benefits}</p>
            <div class="mt-3 flex items-center gap-1.5 text-xs">
              <span class="font-semibold text-ink-700">Daily:</span>
              <span class="text-ink-500">{nutrient.dailyValue}</span>
            </div>
            <div class="mt-3 border-t border-ink-100 pt-3">
              <div class="text-xs font-semibold text-ink-600">Top Sources:</div>
              <div class="mt-2 flex flex-wrap gap-1.5">
                {nutrient.foods.map((food) => (
                  <span class="rounded-md bg-health-50 px-2 py-0.5 text-xs text-health-700">{food}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 食物推荐 -->
  <section class="bg-ink-50 section-padding">
    <div class="container-x">
      <h2 class="text-2xl font-bold text-ink-800 sm:text-3xl">Food Group Recommendations</h2>
      <p class="mt-3 text-ink-500">Daily servings from each food group for a balanced diet.</p>

      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {foodGroups.map((group) => (
          <div class="card">
            <div class="flex items-center gap-3">
              <span class="text-3xl">{group.icon}</span>
              <span class="rounded-full bg-medical-50 px-3 py-1 text-xs font-semibold text-medical-700">{group.count}</span>
            </div>
            <h3 class="mt-4 font-display font-bold text-ink-800">{group.name}</h3>
            <p class="mt-2 text-sm text-ink-500">{group.items}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 饮食方案 -->
  <section class="bg-white section-padding">
    <div class="container-x">
      <h2 class="text-2xl font-bold text-ink-800 sm:text-3xl">Popular Diet Plans</h2>
      <p class="mt-3 text-ink-500">Evidence-based eating patterns for different health goals.</p>

      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        {dietPlans.map((plan) => (
          <div class="card group flex items-start gap-5">
            <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-medical-50 to-health-50 text-4xl">
              {plan.icon}
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <h3 class="font-display text-lg font-bold text-ink-800 group-hover:text-medical-600">{plan.name}</h3>
                <span class="rounded-full bg-health-50 px-2.5 py-0.5 text-xs font-medium text-health-700 ring-1 ring-inset ring-health-200">{plan.badge}</span>
              </div>
              <p class="mt-1 text-sm font-medium text-medical-600">{plan.focus}</p>
              <p class="mt-2 text-sm text-ink-500">{plan.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- AI CTA -->
      <div class="mx-auto mt-16 max-w-4xl overflow-hidden rounded-3xl bg-gradient-to-br from-medical-500 to-health-500 p-8 text-center text-white sm:p-12">
        <div class="text-5xl">🤖</div>
        <h2 class="mt-4 text-2xl font-bold sm:text-3xl">Get a Personalized Nutrition Plan</h2>
        <p class="mx-auto mt-3 max-w-xl text-white/90">
          Tell our AI assistant about your health goals and dietary preferences to receive tailored nutrition recommendations.
        </p>
        <a href={`${basePath}/ai-tools`} class="mt-6 inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-medical-600 transition-colors hover:bg-white/90">
          Get Nutrition Advice
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
        </a>
      </div>

      <!-- 医疗免责声明 -->
      <div class="mx-auto mt-12 max-w-3xl border-t border-ink-100 pt-6">
        <p class="text-center text-xs leading-relaxed text-ink-400">
          ⚠️ Medical Disclaimer: Nutritional information provided is general in nature. Individual needs vary based on age, health conditions, and medications. Consult a registered dietitian or healthcare provider before making significant dietary changes.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
