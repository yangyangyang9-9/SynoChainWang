---
import BaseLayout from '../layouts/BaseLayout.astro';
import AIHealthChecker from '../components/ai/AIHealthChecker';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const features = [
  { icon: '🧠', title: 'AI Symptom Analysis', desc: 'Advanced AI models analyze your symptoms using medical knowledge databases' },
  { icon: '🔬', title: 'Medical Knowledge', desc: 'Trained on comprehensive medical literature and disease databases' },
  { icon: '💡', title: 'Personalized Guidance', desc: 'Get tailored recommendations based on your specific situation' },
  { icon: '⚠️', title: 'Warning Signs', desc: 'AI identifies red-flag symptoms that need immediate medical attention' },
];
---

<BaseLayout title="AI Health Assistant - SynoChain AI" description="Get AI-powered health guidance. Describe your symptoms and receive instant analysis with possible factors, related conditions, and recommended next steps." lang={lang}>
  <section class="relative overflow-hidden bg-white pt-32 pb-16">
    <div class="absolute inset-0 grid-bg opacity-40"></div>
    <div class="container-x relative">
      <div class="mx-auto max-w-3xl text-center">
        <span class="inline-flex items-center gap-2 rounded-full border border-medical-200 bg-medical-50 px-4 py-1.5 text-xs font-medium text-medical-700">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-medical-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-medical-500"></span>
          </span>
          AI-Powered · Medical Knowledge Trained
        </span>
        <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-ink-800 sm:text-5xl">
          {t('ai.title')}
        </h1>
        <p class="mt-4 text-base text-ink-500 sm:text-lg">
          {t('ai.subtitle')}
        </p>

        <!-- Hero Image -->
        <div class="mt-10 mx-auto max-w-2xl">
          <img
            src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=AI%20health%20assistant%20interface%20concept%2C%20futuristic%20medical%20chatbot%20UI%20on%20screen%2C%20blue%20teal%20gradient%2C%20clean%20modern%20design%2C%20digital%20health%20technology&image_size=landscape_16_9"
            alt="AI Health Assistant Interface"
            class="w-full rounded-2xl border border-ink-100 shadow-xl"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white pb-16">
    <div class="container-x">
      <div class="mx-auto max-w-4xl">
        <AIHealthChecker client:load lang={lang} />
      </div>

      <!-- 特性 -->
      <div class="mx-auto mt-20 max-w-5xl">
        <h2 class="text-center text-2xl font-bold text-ink-800 sm:text-3xl">How It Works</h2>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {features.map((f) => (
            <div class="card text-center">
              <div class="mx-auto inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-medical-50 text-3xl">
                {f.icon}
              </div>
              <h3 class="mt-4 font-display text-base font-bold text-ink-800">{f.title}</h3>
              <p class="mt-2 text-sm text-ink-500">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- 免责声明 -->
      <div class="mx-auto mt-12 max-w-3xl rounded-2xl border border-amber-200 bg-amber-50 p-6">
        <div class="flex items-start gap-3">
          <span class="text-2xl">⚠️</span>
          <div>
            <h3 class="font-display text-sm font-bold text-amber-800">Medical Disclaimer</h3>
            <p class="mt-2 text-sm text-amber-700">{t('ai.disclaimer')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
